<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Peace Time Agency — Retro‑Futuristic Social Media Hub</title>
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="description" content="Peace Time Agency: A galactic NGO using content creation and digital diplomacy to foster peace across the stars. Retro‑futuristic, 60s NASA x TikTok creator studio.">
  <meta name="theme-color" content="#0D1B2A">
  <link rel="canonical" href="https://peacetime.agency/">
  <meta name="keywords" content="retrofuturism, space age pop, bento grid, glassmorphism, neon, tiktok studio, creator agency, live, dashboard ui, peace, cosmic">

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Lexend:wght@400;600;700&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">

  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:title" content="Peace Time Agency — Retro‑Futuristic Social Media Hub">
  <meta property="og:description" content="Broadcasting harmony across the timeline with a 60s NASA control room x TikTok creator studio aesthetic.">
  <meta property="og:url" content="https://peacetime.agency/">
  <meta property="og:image" content="https://peacetime.agency/og-retro.png">

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="Peace Time Agency — Retro‑Futuristic Social Media Hub">
  <meta name="twitter:description" content="Broadcasting harmony across the timeline. A NASA control room x TikTok creator studio.">
  <meta name="twitter:image" content="https://peacetime.agency/og-retro.png">

  <style>
    :root{
      --cosmic:#0D1B2A;            /* Deep Cosmic Navy */
      --midnight:#0b0a1e;          /* Midnight Purple leaning base (used in gradients) */
      --purple:#3c0d5a;            /* Midnight Purple reference */
      --solar:#F26419;             /* Neon Solar Orange */
      --pink:#F00699;              /* Cyber Pink */
      --white:#EAF2FF;
      --ink:#C6D2E6;
      --muted:#9FA7BA;
      --line:rgba(255,255,255,.14);
      --glass:rgba(255,255,255,.08);
      --glow-o: 0 0 12px rgba(242,100,25,.5), 0 0 28px rgba(242,100,25,.3);
      --glow-p: 0 0 12px rgba(240,6,153,.5), 0 0 28px rgba(240,6,153,.3);
      --shadow-lg: 0 30px 80px rgba(0,0,0,.55);
      --shadow-md: 0 18px 40px rgba(0,0,0,.45);
      --radius:16px;
      --radius-sm:12px;
      --radius-xs:10px;
      --maxw:1200px;
    }

    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;
      color:var(--white);
      background: radial-gradient(1200px 900px at 100% 0%, rgba(240,6,153,.10), transparent 60%),
                  radial-gradient(1000px 700px at 0% 100%, rgba(242,100,25,.12), transparent 60%),
                  linear-gradient(180deg, var(--midnight), #0a0a17 45%, var(--cosmic));
      font-family: Lexend, system-ui, -apple-system, Segoe UI, Roboto, "Helvetica Neue", Arial;
      -webkit-font-smoothing:antialiased;
      -moz-osx-font-smoothing:grayscale;
      scroll-behavior:smooth;
      overflow-x:hidden;
    }
    .no-scroll{overflow:hidden}

    img,svg{display:block;max-width:100%}
    a{color:inherit;text-decoration:none}
    button{font:inherit}

    /* Film grain + paper texture overlay */
    .fx-layer{
      position:fixed;inset:0;pointer-events:none;z-index:1;
      background-image:
        radial-gradient(rgba(255,255,255,.04) 1px, transparent 1px),
        url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="160" height="160" viewBox="0 0 40 40"><filter id="n"><feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="2" stitchTiles="stitch"/><feColorMatrix type="saturate" values="0"/></filter><rect width="100%" height="100%" filter="url(%23n)"/></svg>');
      background-size: 3px 3px, 160px 160px;
      opacity:.22;
      mix-blend-mode: overlay;
    }
    /* Nebula gradient behind footer */
    .nebula{
      position:fixed;left:0;right:0;bottom:0;height:40vh;z-index:0;pointer-events:none;
      background:
        radial-gradient(60% 60% at 20% 80%, rgba(240,6,153,.35), transparent 60%),
        radial-gradient(50% 60% at 80% 70%, rgba(242,100,25,.28), transparent 60%),
        radial-gradient(50% 40% at 60% 10%, rgba(90,50,160,.28), transparent 60%);
      filter: blur(30px) saturate(140%);
      opacity:.65;
      animation: nebula 18s ease-in-out infinite alternate;
    }
    @keyframes nebula{
      0%{transform:translateY(0)}
      100%{transform:translateY(6vh)}
    }

    .container{width:100%;max-width:var(--maxw);margin:0 auto;padding:0 20px;position:relative;z-index:2}

    /* Floating glass nav */
    .nav{
      position:sticky;top:14px;z-index:10;
      display:flex;justify-content:center;
    }
    .nav-inner{
      width:min(1100px, 94vw);
      display:flex;align-items:center;justify-content:space-between;gap:16px;
      padding:12px 16px;border-radius:18px;
      background:linear-gradient(180deg, rgba(255,255,255,.12), rgba(255,255,255,.06));
      border:1px solid rgba(255,255,255,.16);
      box-shadow: var(--shadow-md);
      backdrop-filter: blur(14px) saturate(160%);
    }
    .brand{
      display:flex;align-items:center;gap:12px;font-family:Montserrat, Lexend, sans-serif;font-weight:800;letter-spacing:.3px
    }
    .brand .badge{
      width:36px;height:36px;border-radius:12px;display:grid;place-items:center;
      background: radial-gradient(circle at 30% 30%, rgba(242,100,25,.8), rgba(240,6,153,.7));
      box-shadow: var(--glow-o), var(--glow-p);
    }
    .brand .badge svg{width:22px;height:22px}
    .nav-links{
      display:flex;gap:18px;align-items:center;color:var(--ink);font-weight:600
    }
    .nav-links a{
      padding:8px 10px;border-radius:12px;transition:.25s;opacity:.92
    }
    .nav-links a:hover{color:var(--white);background:rgba(255,255,255,.08)}
    .nav-cta{display:flex;gap:10px;align-items:center}
    .hamburger{display:none}

    /* Retro toggle buttons */
    .toggle{
      --bd: rgba(255,255,255,.18);
      --bg: rgba(255,255,255,.06);
      position:relative;border-radius:14px;border:1px solid var(--bd);background:var(--bg);
      padding:10px 14px;color:var(--white);font-weight:800;display:inline-flex;align-items:center;gap:10px;cursor:pointer;
      transition: all .25s ease; isolation:isolate;
    }
    .toggle:hover{transform:translateY(-1px);box-shadow:var(--shadow-md)}
    .toggle .led{
      width:10px;height:10px;border-radius:50%;background:linear-gradient(180deg, #bbb, #888);
      box-shadow: inset 0 0 0 2px rgba(0,0,0,.25);
    }
    .toggle[data-variant="solar"]{--accent:#F26419; box-shadow: 0 0 0 1px rgba(242,100,25,.25) inset}
    .toggle[data-variant="pink"]{--accent:#F00699; box-shadow: 0 0 0 1px rgba(240,6,153,.25) inset}
    .toggle.active .led{
      background: radial-gradient(circle at 30% 30%, var(--accent), color-mix(in oklab, var(--accent), black 35%));
      box-shadow: 0 0 10px color-mix(in oklab, var(--accent), white 10%);
    }
    .toggle:focus-visible{outline:2px solid color-mix(in oklab, var(--accent), white 15%)}
    .btn{
      display:inline-flex;align-items:center;gap:10px;padding:12px 16px;border-radius:14px;border:1px solid rgba(255,255,255,.16);
      background:linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.03)); color:var(--white);
      transition: all .25s ease; font-weight:800;
    }
    .btn:hover{transform:translateY(-1px);box-shadow:var(--shadow-md)}
    .btn.solar{box-shadow:var(--glow-o)}
    .btn.pink{box-shadow:var(--glow-p)}

    /* Hero */
    .hero{
      position:relative;padding:72px 0 28px;
    }
    .hero .grid{
      display:grid;grid-template-columns: 1.1fr .9fr;gap:32px;align-items:center;
    }
    .kicker{
      display:inline-flex;align-items:center;gap:8px;padding:8px 12px;border-radius:999px;border:1px dashed rgba(255,255,255,.24);
      background:rgba(255,255,255,.06);color:#dfe6f9;font-weight:700;letter-spacing:.3px;text-transform:uppercase;font-size:12px
    }
    .kicker .ping{
      width:10px;height:10px;border-radius:50%;background:var(--pink);box-shadow:0 0 10px var(--pink)
    }
    h1{
      font-family:Montserrat, Lexend, sans-serif;
      font-size: clamp(34px, 5.2vw, 68px);
      line-height:1.02;margin:12px 0 12px;font-weight:800;letter-spacing:-.02em
    }
    h1 .solar{color:var(--solar);text-shadow:0 0 24px rgba(242,100,25,.35)}
    .sub{color:var(--ink);font-size:clamp(16px, 1.8vw, 18px);max-width:760px}
    .hero-actions{display:flex;flex-wrap:wrap;gap:12px;margin:18px 0 0}
    .mono{font-family:"JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;color:#d8def0}

    /* Peace Clock + Orbitals */
    .stage{
      position:relative;border-radius:20px;border:1px solid rgba(255,255,255,.16);
      background: linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.03));
      box-shadow: var(--shadow-lg);
      overflow:hidden;min-height:520px;
      backdrop-filter: blur(8px);
    }
    #starfield{position:absolute;inset:0}
    .centerpiece{
      position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);display:grid;place-items:center
    }
    /* Peace symbol */
    .peace{
      width:min(360px, 62vw); aspect-ratio:1/1; position:relative; filter: drop-shadow(0 8px 24px rgba(240,6,153,.35));
    }
    .peace svg{width:100%;height:100%}
    .peace .ring{
      position:absolute;inset:0;border-radius:50%;border:2px dashed rgba(240,6,153,.22);
      animation: spin 26s linear infinite; pointer-events:none
    }
    .peace .ring.r2{border-color:rgba(242,100,25,.22);animation-duration:36s}
    .peace .ring.r3{border-color:rgba(90,60,160,.22);animation-duration:44s}
    @keyframes spin{to{transform:rotate(360deg)}}

    .clock{
      position:absolute;inset:0;display:grid;place-items:center;pointer-events:none;
    }
    .clock .label{
      position:absolute;bottom:18px;left:50%;transform:translateX(-50%);
      font-family:"JetBrains Mono";font-size:14px;color:#dfe6f9;opacity:.9
    }

    /* Transmission Grid (Active Transmissions) */
    .section{padding:72px 0}
    .section .head{
      display:flex;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:18px
    }
    .section h2{
      font-family:Montserrat, Lexend, sans-serif;font-size:clamp(26px, 3.2vw, 38px);margin:0;font-weight:800
    }
    .bento{
      display:grid;grid-template-columns:repeat(12,1fr);gap:14px
    }
    .card{
      grid-column: span 4; border-radius:18px;border:1px solid var(--line);
      background:linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.03));
      box-shadow:var(--shadow-md); overflow:hidden; position:relative;
    }
    .card.tall{grid-row: span 2}
    .card.wide{grid-column: span 8}
    .card .pad{padding:16px}
    .card h3{margin:0 0 6px;font-size:18px}
    .card p{margin:0;color:var(--ink)}

    /* Video placeholder as TikTok/Reels-like frame */
    .frame{
      aspect-ratio: 9/16; border-bottom:1px solid var(--line); position:relative; overflow:hidden;
      background:
        radial-gradient(40% 40% at 20% 20%, rgba(240,6,153,.35), transparent 60%),
        radial-gradient(40% 40% at 80% 80%, rgba(242,100,25,.35), transparent 60%),
        linear-gradient(180deg, #14132a, #0f1224);
    }
    .frame .ui{
      position:absolute;inset:0;display:flex;justify-content:space-between;pointer-events:none;
    }
    .frame .pill{
      position:absolute;top:12px;left:12px;background:rgba(0,0,0,.35);backdrop-filter: blur(6px);
      border:1px solid rgba(255,255,255,.18);border-radius:999px;padding:6px 10px;font-size:12px;font-weight:800;display:flex;gap:8px;align-items:center;
    }
    .live-dot{width:8px;height:8px;border-radius:50%;background:#ff4f7a;box-shadow:0 0 10px #ff4f7a}
    .frame .side{
      display:flex;flex-direction:column;gap:12px;align-items:center;justify-content:flex-end;padding:12px
    }
    .icon-btn{
      width:42px;height:42px;border-radius:50%;display:grid;place-items:center;
      background:rgba(0,0,0,.36);border:1px solid rgba(255,255,255,.2);backdrop-filter: blur(6px);
      color:#fff
    }
    .statsbar{
      position:absolute;left:10px;bottom:10px;right:10px;display:flex;gap:8px;align-items:center;justify-content:space-between;
      pointer-events:none
    }
    .tag{font-family:"JetBrains Mono";font-size:12px;padding:6px 10px;border-radius:999px;border:1px dashed rgba(255,255,255,.22);background:rgba(255,255,255,.06)}
    .chip{padding:6px 10px;border-radius:10px;border:1px solid rgba(255,255,255,.14);background:rgba(0,0,0,.24);backdrop-filter: blur(6px);font-size:12px}

    /* Peace Stats */
    .stats{
      display:grid;grid-template-columns:repeat(4,1fr);gap:14px
    }
    .kpi{
      border-radius:18px;border:1px solid var(--line);
      background:linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.03));
      padding:16px;text-align:center
    }
    .kpi .val{
      font-family:Montserrat, Lexend, sans-serif;font-size:32px;font-weight:800;
      background:linear-gradient(90deg, #fff, #ffd7c7 30%, #ffe6f8 70%);-webkit-background-clip:text;background-clip:text;color:transparent
    }
    .kpi .lab{color:var(--ink);font-size:12px;margin-top:6px}

    /* Recruitment */
    .recruit{
      display:grid;grid-template-columns: 1.1fr .9fr;gap:16px
    }
    form{
      border-radius:18px;border:1px solid var(--line);
      background:linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.03));
      padding:16px
    }
    .row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
    .field{margin-bottom:12px}
    label{display:block;margin:0 0 6px;color:#dfe6f9;font-weight:700}
    input,select,textarea{
      width:100%;padding:12px;border-radius:12px;border:1px solid rgba(255,255,255,.18);background:#0d1024;color:#fff;outline:none
    }
    textarea{min-height:120px;resize:vertical}
    input:focus,select:focus,textarea:focus{border-color:var(--pink);box-shadow:0 0 0 3px rgba(240,6,153,.22)}
    .help{font-size:12px;color:#b8c0d8;margin-top:6px}
    .success{display:none;margin-top:10px;padding:12px;border-radius:12px;border:1px solid rgba(242,100,25,.3);background:linear-gradient(180deg, rgba(242,100,25,.14), rgba(242,100,25,.06));color:#fff}
    .error{color:#ff9fb2;font-size:12px;margin-top:6px;display:none}

    /* Footer */
    footer{
      position:relative;margin-top:40px;border-top:1px solid rgba(255,255,255,.12);
      padding:28px 0;color:#cfd6eb
    }
    .foot-grid{display:grid;grid-template-columns:1.2fr .8fr .8fr;gap:16px}
    .foot-brand{display:flex;align-items:center;gap:10px}
    .foot-brand .logo{
      width:34px;height:34px;border-radius:10px;background:linear-gradient(135deg, rgba(242,100,25,.8), rgba(240,6,153,.7));
      box-shadow: var(--glow-o), var(--glow-p)
    }
    .socials{display:flex;gap:10px;margin-top:10px}
    .socials a{
      width:36px;height:36px;border-radius:10px;border:1px solid rgba(255,255,255,.14);
      display:grid;place-items:center;background:rgba(255,255,255,.06)
    }

    /* Reveal */
    .reveal{opacity:0;transform:translateY(16px);transition:all .7s ease}
    .reveal.in{opacity:1;transform:none}

    /* Responsive */
    @media (max-width: 1024px){
      .hero .grid{grid-template-columns:1fr;gap:20px}
      .stage{min-height:480px}
      .bento{grid-template-columns:repeat(6,1fr)}
      .card.wide{grid-column: span 6}
      .card{grid-column: span 3}
      .recruit{grid-template-columns:1fr}
      .stats{grid-template-columns:repeat(2,1fr)}
      .nav-links{display:none}
      .hamburger{display:inline-flex}
    }
    @media (max-width: 720px){
      .bento{grid-template-columns:repeat(4,1fr)}
      .card{grid-column: span 4}
      .stage{min-height:420px}
      .row{grid-template-columns:1fr}
    }
    @media (prefers-reduced-motion: reduce){
      .nebula,.peace .ring{animation:none!important}
    }
  </style>
</head>
<body>
  <div class="fx-layer" aria-hidden="true"></div>
  <div class="nebula" aria-hidden="true"></div>

  <header class="nav">
    <div class="nav-inner">
      <a href="#" class="brand" aria-label="Peace Time Agency">
        <span class="badge" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22"><path fill="currentColor" d="M12 2a10 10 0 1 0 .001 20.001A10 10 0 0 0 12 2zm-6.7 14.1l1.4 1.4 4.3-4.3 4.3 4.3 1.4-1.4-5.7-5.7-5.7 5.7z"/></svg>
        </span>
        <span>Peace Time Agency</span>
      </a>
      <nav class="nav-links" aria-label="Primary">
        <a href="#transmissions">Transmissions</a>
        <a href="#stats">Peace Stats</a>
        <a href="#recruit">Agent Recruitment</a>
        <a href="#contact">Contact</a>
      </nav>
      <div class="nav-cta">
        <a href="#recruit" class="btn solar">Join the Corps</a>
        <button class="btn pink hamburger" id="menuBtn" aria-label="Open menu">
          <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M3 6h18v2H3zm0 5h18v2H3zm0 5h18v2H3z"/></svg>
        </button>
      </div>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container">
        <div class="grid">
          <div>
            <span class="kicker"><span class="ping"></span> Retro‑Futuristic Social Media Hub</span>
            <h1>
              Broadcasting <span class="solar">Harmony</span> Across the Timeline
            </h1>
            <p class="sub">
              We’re a galactic NGO using content creation and digital diplomacy to foster peace across the stars. Welcome to our command center — a 1960s NASA control room meets a modern TikTok creator studio.
            </p>
            <div class="hero-actions">
              <a href="#recruit" class="btn solar">
                <svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M5 12h14v2H5zm0-5h14v2H5zm0 10h14v2H5z"/></svg>
                Apply to Agent Program
              </a>
              <button class="toggle" data-variant="pink" id="modeToggle" aria-pressed="false">
                <span class="led" aria-hidden="true"></span>
                Transmission Mode
              </button>
            </div>
            <p class="mono" style="margin-top:10px;opacity:.85">Agency ID: PTA‑Ω‑1969 • Clearance: Peaceful</p>
          </div>
          <div class="stage">
            <canvas id="starfield" aria-hidden="true"></canvas>
            <div class="centerpiece">
              <div class="peace" aria-hidden="true">
                <!-- Peace symbol -->
                <svg viewBox="0 0 100 100">
                  <defs>
                    <radialGradient id="g" cx="50%" cy="50%" r="60%">
                      <stop offset="0%" stop-color="#fff" stop-opacity="0.9"/>
                      <stop offset="100%" stop-color="#F00699" stop-opacity="0.6"/>
                    </radialGradient>
                  </defs>
                  <circle cx="50" cy="50" r="40" fill="url(#g)"></circle>
                  <line x1="50" y1="10" x2="50" y2="90" stroke="#0b0b16" stroke-width="6" />
                  <line x1="50" y1="50" x2="15" y2="85" stroke="#0b0b16" stroke-width="6" />
                  <line x1="50" y1="50" x2="85" y2="85" stroke="#0b0b16" stroke-width="6" />
                </svg>
                <div class="ring r1"></div>
                <div class="ring r2"></div>
                <div class="ring r3"></div>
              </div>
              <div class="clock" aria-live="polite">
                <div class="label mono" id="clock">00:00:00 • Galactic Standard</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="transmissions" class="section">
      <div class="container">
        <div class="head">
          <h2>Active Transmissions</h2>
          <div class="toggle" data-variant="solar" id="liveToggle" aria-pressed="true">
            <span class="led" aria-hidden="true"></span>
            Live Feed
          </div>
        </div>

        <div class="bento">
          <!-- Featured wide stream -->
          <article class="card wide tall reveal">
            <div class="frame">
              <div class="ui">
                <div class="pill"><span class="live-dot"></span> LIVE</div>
                <div class="side">
                  <button class="icon-btn" aria-label="Boost signal"><svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M12 2l4 6H8l4-6zm-7 9h2l3 7 4-14 3 14h2L5 11z"/></svg></button>
                  <button class="icon-btn" aria-label="Translate message"><svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M3 5h12v2H3zm0 14h12v2H3zM5 9h8v2H5zm0 6h8v2H5zM17 5l-3 10h2l1-4h4l1 4h2L17 5z"/></svg></button>
                  <button class="icon-btn" aria-label="Share signal"><svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M18 8a3 3 0 0 0-2.82 2H8.82A3 3 0 1 0 6 8a3 3 0 0 0 .06.6L13 12V8a3 3 0 1 0 2 0v6a3 3 0 0 0-.06-.6L10 13l6-3.4A3 3 0 1 0 18 8z"/></svg></button>
                </div>
              </div>
              <div class="statsbar">
                <span class="tag">Mission: Ceasefire Session</span>
                <span class="chip mono" id="liveViewers">— viewing</span>
              </div>
            </div>
            <div class="pad">
              <h3>Ceasefire Session • Orbital Session 07</h3>
              <p>Digital diplomacy at scale. Co‑hosted with cross‑faction creators to broadcast ceasefire signals and coordinate relief streams.</p>
            </div>
          </article>

          <!-- Three smaller transmissions -->
          <article class="card reveal">
            <div class="frame" style="aspect-ratio:auto;height:220px">
              <div class="ui">
                <div class="pill">Rebroadcast</div>

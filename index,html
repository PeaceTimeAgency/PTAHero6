  <script>
    // Toggle helper
    function bindToggle(el){
      if (!el) return;
      el.addEventListener('click', ()=>{
        el.classList.toggle('active');
        el.setAttribute('aria-pressed', el.classList.contains('active'));
      });
    }
    bindToggle(document.getElementById('modeToggle'));
    bindToggle(document.getElementById('liveToggle'));
    bindToggle(document.getElementById('briefing1'));
    bindToggle(document.getElementById('briefing2'));

    // Simple mobile menu
    const menuBtn = document.getElementById('menuBtn');
    menuBtn?.addEventListener('click', ()=>{
      document.body.classList.toggle('no-scroll');
      const links = document.querySelector('.nav-links');
      if (!links) return;
      if (links.style.display === 'flex') {
        links.style.display = '';
      } else {
        links.style.display = 'flex';
        links.style.flexDirection = 'column';
        links.style.position = 'absolute';
        links.style.top = '64px';
        links.style.right = '20px';
        links.style.background = 'rgba(13,16,36,.92)';
        links.style.border = '1px solid rgba(255,255,255,.14)';
        links.style.borderRadius = '12px';
        links.style.padding = '12px';
        // close on link click
        links.querySelectorAll('a').forEach(a => a.onclick = () => links.style.display = '');
      }
    });

    // Peace Clock
    function updateClock(){
      const now = new Date();
      const pad = n => n.toString().padStart(2,'0');
      const t = `${pad(now.getUTCHours())}:${pad(now.getUTCMinutes())}:${pad(now.getUTCSeconds())}`;
      document.getElementById('clock').textContent = `${t} • Galactic Standard`;
    }
    setInterval(updateClock, 1000);
    updateClock();

    // Starfield canvas
    const canvas = document.getElementById('starfield');
    const ctx = canvas.getContext('2d', { alpha: true });
    let stars = [];
    let w=0, h=0, cx=0, cy=0;
    function resize(){
      const rect = canvas.getBoundingClientRect();
      w = canvas.width = rect.width * devicePixelRatio;
      h = canvas.height = rect.height * devicePixelRatio;
      canvas.style.width = rect.width + 'px';
      canvas.style.height = rect.height + 'px';
      cx = w/2; cy = h/2;
      const count = Math.min(220, Math.floor((w*h)/(15000)));
      stars = Array.from({length:count}, ()=>({
        x:(Math.random()*w - cx)/2,
        y:(Math.random()*h - cy)/2,
        z:Math.random()*1 + .2,
        r: Math.random()*1.2 + .2,
        tw: Math.random()*Math.PI*2
      }));
    }
    const observer = new ResizeObserver(resize);
    observer.observe(canvas);
    function draw(){
      ctx.clearRect(0,0,w,h);
      ctx.save();
      ctx.translate(cx,cy);
      const t = Date.now() * 0.0006;
      for (let s of stars){
        const ox = s.x * Math.cos(t) - s.y * Math.sin(t);
        const oy = s.x * Math.sin(t) + s.y * Math.cos(t);
        const x = ox * (1 + s.z*0.6);
        const y = oy * (1 + s.z*0.6);
        const alpha = 0.6 + Math.sin(t*3 + s.tw) * 0.25;
        ctx.beginPath();
        ctx.fillStyle = `rgba(${s.z>0.9? '255,224,220':'200,220,255'},${alpha})`;
        ctx.arc(x, y, s.r, 0, Math.PI*2);
        ctx.fill();
      }
      ctx.restore();
      requestAnimationFrame(draw);
    }
    draw();

    // Live viewers counter (simulated)
    const liveViewers = document.getElementById('liveViewers');
    function human(n){
      if (n >= 1_000_000) return (n/1_000_000).toFixed(1).replace(/\.0$/,'') + 'M';
      if (n >= 10_000) return (n/1000).toFixed(1).replace(/\.0$/,'') + 'k';
      return '' + Math.round(n);
    }
    let viewers = 12400;
    setInterval(()=>{
      viewers += Math.round((Math.random()*80)-40);
      if (viewers < 8000) viewers = 8000;
      if (viewers > 48000) viewers = 48000;
      if (liveViewers) liveViewers.textContent = `${human(viewers)} viewing`;
    }, 2500);

    // Reveal on scroll
    const io = new IntersectionObserver(entries=>{
      entries.forEach(en=>{
        if (en.isIntersecting) {
          en.target.classList.add('in');
          io.unobserve(en.target);
        }
      })
    }, { threshold:.12 });
    document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

    // Peace Stats counters
    const ioK = new IntersectionObserver(entries=>{
      entries.forEach(en=>{
        if (en.isIntersecting) {
          const el = en.target;
          const target = parseFloat(el.dataset.count);
          const isFloat = !Number.isInteger(target);
          const suffix = el.textContent.trim().endsWith('Sectors Reached') ? '' :
                         el.textContent.trim().includes('.') ? '' :
                         el.textContent.trim().includes('%') ? '%' :
                         el.textContent.trim().includes('M') ? 'M' :
                         el.textContent.trim().includes('k') ? 'k' : '';
          const duration = 1400;
          const start = performance.now();
          function step(now){
            const p = Math.min(1, (now - start)/duration);
            const eased = 1 - Math.pow(1 - p, 3);
            const val = target * (0.1 + 0.9 * eased);
            el.textContent = isFloat ? val.toFixed(1).replace(/\.0$/,'') : Math.round(val);
            if (p < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
          ioK.unobserve(el);
        }
      })
    }, { threshold:.4 });
    document.querySelectorAll('.kpi .val').forEach(el=>ioK.observe(el));

    // Form handling
    const form = document.getElementById('applyForm');
    const success = document.getElementById('formSuccess');
    const FORM_ENDPOINT = ""; // Set to your production endpoint to enable real submissions
    function showErr(id, on){ const e = document.getElementById(id); if (e) e.style.display = on ? 'block' : 'none'; }
    function validEmail(v){ return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v); }
    form?.addEventListener('submit', async (e)=>{
      e.preventDefault();
      ['err-name','err-email','err-skill','err-clearance','err-pitch'].forEach(id=>showErr(id,false));
      const data = Object.fromEntries(new FormData(form).entries());
      let ok = true;
      if (!data.name) { showErr('err-name', true); ok=false; }
      if (!validEmail(data.email||'')) { showErr('err-email', true); ok=false; }
      if (!data.skill) { showErr('err-skill', true); ok=false; }
      if (!data.clearance) { showErr('err-clearance', true); ok=false; }
      if (!data.pitch || data.pitch.trim().length < 12) { showErr('err-pitch', true); ok=false; }
      if (!ok) return;
      const btn = form.querySelector('button[type="submit"]');
      const original = btn.innerHTML;
      btn.disabled = true; btn.innerHTML = 'Transmitting...';
      try{
        let sent = false;
        if (FORM_ENDPOINT) {
          const res = await fetch(FORM_ENDPOINT, {
            method:'POST', headers:{'Content-Type':'application/json'},
            body: JSON.stringify({ ...data, source:'peacetime.agency/retro', ts:new Date().toISOString() })
          });
          sent = res.ok;
        } else {
          await new Promise(r=>setTimeout(r, 900));
          sent = true;
        }
        if (sent) {
          success.style.display='block';
          form.reset();
          success.scrollIntoView({behavior:'smooth', block:'center'});
        } else {
          alert('Transmission error. Please email hello@peacetime.agency.');
        }
      } catch(err){
        alert('Network error. Please email hello@peacetime.agency.');
      } finally {
        btn.disabled = false; btn.innerHTML = original;
      }
    });

    // Year
    document.getElementById('year').textContent = new Date().getFullYear();

    // Accessibility: focus outline for keyboard users
    let hadKeyboardEvent = false;
    const root = document.documentElement;
    function handleFirstTab(e){
      if (e.key === 'Tab') {
        root.classList.add('user-is-tabbing');
        hadKeyboardEvent = true;
        window.removeEventListener('keydown', handleFirstTab);
      }
    }
    window.addEventListener('keydown', handleFirstTab);

    // Schema.org
    const orgLd = {
      "@context":"https://schema.org",
      "@type":"Organization",
      "name":"Peace Time Agency",
      "url":"https://peacetime.agency/",
      "logo":"https://peacetime.agency/logo-retro.png",
      "sameAs":[
        "https://www.tiktok.com/@peacetimeagency",
        "https://www.instagram.com/peacetimeagency",
        "https://www.linkedin.com/company/peacetime-agency"
      ],
      "description":"Retro‑futuristic social media hub fostering peace across the stars with creator‑first live broadcasts and digital diplomacy."
    };
    const s = document.createElement('script');
    s.type='application/ld+json'; s.textContent = JSON.stringify(orgLd);
    document.head.appendChild(s);
  </script>
